VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay publishable Key ID — safe in the browser, used by Checkout.
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Server-side secrets — set these in Supabase (Edge Functions → Secrets), NOT in Vite.
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase.
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
